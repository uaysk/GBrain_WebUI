GBRAIN_DB_HOST=127.0.0.1
GBRAIN_DB_PORT=5432
GBRAIN_DB_NAME=
GBRAIN_DB_USER=
GBRAIN_DB_PASSWORD=
GBRAIN_DB_SCHEMA=public
GBRAIN_ALLOWED_SOURCE_IDS=default

# Leiden community detection
LEIDEN_RESOLUTION=0.5
LEIDEN_MIN_SEMANTIC_SIMILARITY=0.65
LEIDEN_SEED=84

APP_HOST=127.0.0.1
APP_PORT=3000
# Docker Compose가 host에 게시할 주소/포트
APP_PUBLISHED_HOST=127.0.0.1
APP_PUBLISHED_PORT=3100
# Reverse proxy가 전달하는 공개 origin. 예: https://memory.example.com
APP_PUBLIC_ORIGIN=
APP_REBUILD_MIN_INTERVAL_SECONDS=15

# 앱 접근 인증. APP_AUTH_PASSWORD에는 별도의 최소 길이 제한이 없음
APP_AUTH_PASSWORD=
APP_SESSION_SECRET=
APP_AUTH_SESSION_HOURS=12
APP_AUTH_MAX_ATTEMPTS=5
APP_AUTH_ATTEMPT_WINDOW_MINUTES=15
